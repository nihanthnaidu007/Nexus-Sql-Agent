## NIXUS SQL — Environment variables
## Copy to .env (`cp .env.example .env`) and set the TWO API keys below.
##
## Fast path: `scripts/setup.sh` does the copy, prompts for the keys (without
## echoing them), and brings the SaaS demo up. The default `docker compose up`
## stack is SELF-CONTAINED against the bundled SaaS sample — no connection string
## and no external database required. (Bring-your-own-database is STEP TWO, below.)

# ── REQUIRED: LLM / embedding API keys (the ONLY thing you must supply) ───────
# These cannot be precomputed for you: schema embeddings need a live OpenAI call,
# and answering a query needs a live Anthropic call. The stack FAILS FAST at boot
# with a clear message if either is still a placeholder.
OPENAI_API_KEY=your_openai_api_key_here       # schema embeddings (text-embedding-3-small)
ANTHROPIC_API_KEY=your_anthropic_api_key_here # the agent LLM (scope, SQL, explanation)

# ── Databases (split into two connections in 2.1) ────────────────────────────
# NIXUS talks to TWO databases:
#
#   state_db  (READ-WRITE)  — NIXUS-owned bookkeeping: schema_embeddings,
#                             fewshot_examples, query_cache, schema_migrations,
#                             and the LangGraph checkpointer tables.
#   target_db (READ-ONLY)   — the user's data. The generated SQL is executed
#                             here through a Postgres role that holds ONLY SELECT.
#                             Read-only is enforced by Postgres, not by the app.
#
# Local dev: both live in the one Postgres container — nixus_sql (state) and the
# DEFAULT target nixus_saas. (Under `docker compose`, the compose file overrides
# these with @db:5432 URLs; for a local .venv run, these localhost URLs are used.)

# state_db — read-write, owner role. (Legacy DATABASE_URL is still honored as a
# fallback if STATE_DATABASE_URL is unset.)
STATE_DATABASE_URL=postgresql://nixus:nixus@localhost:5433/nixus_sql

# target_db — READ-ONLY. The nixus_readonly role can SELECT and nothing else.
# DEFAULT target is the bundled SaaS sample (nixus_saas).
TARGET_DATABASE_URL=postgresql://nixus_readonly:nixus_readonly@localhost:5433/nixus_saas

# Writable OWNER connection to the target DB — used ONLY for the one-time
# load/seed (scripts/rebuild_saas_db.py and the idempotent ensure step). The app
# NEVER uses this; its only handle to the target is the read-only URL above.
TARGET_ADMIN_DATABASE_URL=postgresql://nixus:nixus@localhost:5433/nixus_saas

# schema_embeddings is populated by introspecting target_db (the only schema
# source): `python -m nixus.schema.reembed`. Run it after the target changes.
# (Embedding requires OPENAI_API_KEY.)

# ── Switching the target — ONE operation (no three-setting juggling) ─────────
# Point the WHOLE stack (API + embeddings + benchmark) at a target with a single
# command — it sets both TARGET_* URLs here AND re-embeds, then asks you to
# restart the API:
#
#     scripts/use_target.sh saas        # the bundled SaaS sample (default)
#     scripts/use_target.sh chinook     # the alt Chinook sample
#
# ── STEP TWO — bring your OWN database (real use) ────────────────────────────
# Point NIXUS at your own Postgres using a role that holds ONLY SELECT (ideally a
# read replica). NIXUS needs nothing more than SELECT on the target:
#
#     scripts/use_target.sh postgresql://readonly_user:pw@your-host:5432/yourdb
#     # then restart the API. Query your real data — read-only, enforced by PG.
#
# (Chinook is also bundled as a second sample; rebuild a sample explicitly with
#  `.venv/bin/python scripts/rebuild_saas_db.py [--verify]`.)

# Optional: override URL for Chinook JSON (default is GitHub raw lerocha/chinook-database).
#CHINOOK_JSON_URL=https://raw.githubusercontent.com/lerocha/chinook-database/master/ChinookDatabase/DataSources/ChinookData.json
# Optional: copy Chinook from another Postgres that has lowercase tables (genre, artist, …) instead of JSON.
#CHINOOK_SOURCE_URL=postgresql://nixus:nixus@localhost:5433/chinook

# ── Optional Tuning ──────────────────────────────────────────────────────────
SCHEMA_RETRIEVAL_TOP_K=6
FEWSHOT_RETRIEVAL_TOP_K=3
FEWSHOT_SIMILARITY_THRESHOLD=0.60
CACHE_SIMILARITY_THRESHOLD=0.92
MAX_CORRECTION_ATTEMPTS=3

# Maximum time in milliseconds a single SQL query is allowed to run.
# PostgreSQL will cancel queries that exceed this limit.
# Increase for complex analytical queries on large datasets.
QUERY_TIMEOUT_MS=30000

# Max number of slices before a distribution chart falls back to bar.
# Increase for dashboards with more categories.
PIE_MAX_SLICES=6

# Cache eviction settings
# Entries not accessed within CACHE_MAX_AGE_DAYS are removed on eviction.
# CACHE_MAX_ENTRIES caps the total cache size; excess entries are removed LRU.
CACHE_MAX_AGE_DAYS=30
CACHE_MAX_ENTRIES=10000

# Logging level: DEBUG, INFO, WARNING, ERROR
# Set to DEBUG to see node-level events and embedding call details.
LOG_LEVEL=INFO

# How long (seconds) to cache LLM connectivity status in /api/health.
# Prevents burning API tokens on every 30-second Streamlit health probe.
LLM_HEALTH_CACHE_TTL=300

# ── Agent / UI ────────────────────────────────────────────────────────────────
# API base URL (default shown — change if running on different port)
#API_BASE_URL=http://localhost:8000

# ── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins. In production, set this to your
# exact UI hostname. In local dev, the default covers Streamlit's port.
# Example: https://nixus-ui.railway.app,http://localhost:8501
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ─────────────────────────────────────────
# LangSmith Observability (optional but recommended)
# Sign up free at https://smith.langchain.com
# ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=nixus-sql
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
