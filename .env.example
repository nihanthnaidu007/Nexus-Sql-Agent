## NEXUS SQL — Environment variables
## Copy to .env and fill in all values before running.

# ── LLM APIs ────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_api_key_here
OPENAI_API_KEY=your_openai_api_key_here

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://user:password@localhost:5432/nexus_sql

# ── Optional Tuning ──────────────────────────────────────────────────────────
SCHEMA_RETRIEVAL_TOP_K=6
FEWSHOT_RETRIEVAL_TOP_K=3
FEWSHOT_SIMILARITY_THRESHOLD=0.60
CACHE_SIMILARITY_THRESHOLD=0.92
MAX_CORRECTION_ATTEMPTS=3
QUERY_EXECUTION_TIMEOUT_SECONDS=10

# ── Agent / UI ────────────────────────────────────────────────────────────────
# API base URL (default shown — change if running on different port)
#API_BASE_URL=http://localhost:8000

# ─────────────────────────────────────────
# LangSmith Observability (optional but recommended)
# Sign up free at https://smith.langchain.com
# ─────────────────────────────────────────
LANGCHAIN_TRACING_V2=true
LANGCHAIN_API_KEY=your_langsmith_key_here
LANGCHAIN_PROJECT=nexus-sql
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
